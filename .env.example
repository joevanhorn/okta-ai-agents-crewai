# =============================================================================
# Account Risk Monitor — configuration template
# Copy to .env (setup.sh does this) and fill in the values for YOUR environment.
# All <...> values are placeholders.
# =============================================================================

# --- 1. LLM -----------------------------------------------------------------
# Pick ONE option.
#
# Option A — LiteLLM proxy / gateway.
#   CrewAI is LiteLLM under the hood. Point it at your proxy and pass the key;
#   LiteLLM proxies are OpenAI-compatible, so prefix the model with "openai/".
# LITELLM_API_BASE=https://your-litellm-proxy.example.com
# LITELLM_API_KEY=sk-your-litellm-virtual-key
# MONITOR_LLM=openai/your-proxy-model
#
# Option B — direct provider key (e.g. Anthropic).
# ANTHROPIC_API_KEY=your-anthropic-api-key
MONITOR_LLM=anthropic/claude-haiku-4-5-20251001

# --- 2. Okta agent identity -------------------------------------------------
# A dedicated Okta API Services app (client_credentials + private_key_jwt) that
# represents the crew. See terraform/crewai_monitor.tf.example to provision one.
OKTA_CLIENT_ID=<your-client-id>
OKTA_KEY_ID=<your-key-id>

# Token endpoint of the custom authorization server that fronts your MCP backend.
OKTA_TOKEN_URL=https://your-org.okta.com/oauth2/<auth-server-id>/v1/token

# The agent's RSA private key. Provide it ONE of these ways (file is simplest):
OKTA_PRIVATE_KEY_FILE=/full/path/to/agent-private-key.pem
# OKTA_PRIVATE_KEY_PEM=<the PEM contents, newlines escaped as \n>
# Or pull it from AWS SSM (set the parameter name + an AWS profile/region with access):
# OKTA_PRIVATE_KEY_SSM_PARAM=/your-path/agent-private-key
# AWS_PROFILE=<your-aws-profile>
# AWS_REGION=us-east-2

# --- 3. MCP backend ---------------------------------------------------------
# Your backend MCP server (NOT an OAuth adapter/broker — see the README).
MCP_BACKEND_URL=https://your-mcp-backend.example.com/mcp

# Scopes to request (the ceiling on what tools the crew can see). The example
# scenario assumes a backend exposing Salesforce + ServiceNow tools gated by
# sfdc:read / sfdc:write / snow:read / snow:write scopes. Adjust to your backend.
MONITOR_SCOPES=sfdc:read sfdc:write snow:read

# Seconds between passes in --watch mode.
WATCH_INTERVAL=300
